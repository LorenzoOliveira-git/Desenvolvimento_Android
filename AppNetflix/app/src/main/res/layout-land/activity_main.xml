<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#161417"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="783dp"
        android:layout_height="345dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="2dp">

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="match_parent"
            android:layout_height="376dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/capa" />


        <LinearLayout
            android:layout_width="552dp"
            android:layout_height="39dp"
            android:layout_gravity="center"

            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView12"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="Violência"
                android:textColor="#FFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView13"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="Empolgante"
                android:textColor="#FFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="Sinistro"
                android:textColor="#FFFF"
                android:textSize="16sp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/imageView7"
            android:layout_width="0dp"
            android:layout_height="82dp"
            app:srcCompat="@drawable/logo" />

        <LinearLayout
            android:layout_width="467dp"
            android:layout_height="104dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="75dp"
            android:layout_marginTop="55dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="Séries"
                android:textColor="#FFFF"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/imageView6"
                android:layout_width="23dp"
                android:layout_height="83dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/logo_peaky" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Filmes"
                android:textColor="#FFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/textView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="Minha Lista"
                android:textColor="#FFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imageView14"
            android:layout_width="44dp"
            android:layout_height="71dp"
            android:layout_marginLeft="120dp"
            android:layout_marginTop="45dp"
            app:srcCompat="@drawable/logo" />

        <LinearLayout
            android:layout_width="678dp"
            android:layout_height="76dp"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="83dp"
                android:layout_gravity="center"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="39dp"
                    android:layout_height="35dp"
                    android:layout_gravity="center_horizontal"
                    app:srcCompat="@drawable/add" />

                <TextView
                    android:id="@+id/textView8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="MINHA LISTA"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/imageButton3"
                android:layout_width="150dp"
                android:layout_height="54dp"
                android:layout_gravity="top"
                app:srcCompat="@drawable/botao_assistir" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/imageView9"
                    android:layout_width="27dp"
                    android:layout_height="29dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="5dp"
                    app:srcCompat="@drawable/info" />

                <TextView
                    android:id="@+id/textView10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="DETALHES"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/textView15"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginLeft="85dp"
            android:layout_marginBottom="65dp"
            android:text="Lançamentos"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="63dp"
            android:layout_gravity="bottom"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageView8"
                android:layout_width="95dp"
                android:layout_height="59dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/f1" />

            <ImageView
                android:id="@+id/imageView10"
                android:layout_width="88dp"
                android:layout_height="59dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/f2" />


            <ImageView
                android:id="@+id/imageView11"
                android:layout_width="88dp"
                android:layout_height="59dp"
                android:layout_weight="1"
                app:srcCompat="@drawable/f3" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>